{
  "expo": {
    "name": "Libreria Lachi",
    "slug": "LibreriaLachi",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/adaptive-icon.png",
    "scheme": "movillibreria",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": "2",
    "updates": {
      "url": "https://u.expo.dev/7398a946-b497-4ac4-9efb-e77ff1a96ec3",
      "fallbackToCacheTimeout": 0,
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "icon": "./assets/images/Logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.pelusaaal.movillibrerialachi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "imageWidth": 200,
          "imageHeight": 200,
          "android": {
            "image": "./assets/icons/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      "expo-web-browser",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "infoPlist": {
              "NSAppTransportSecurity": {
                "NSAllowsArbitraryLoads": true
              }
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7398a946-b497-4ac4-9efb-e77ff1a96ec3"
      }
    }
  }
}
